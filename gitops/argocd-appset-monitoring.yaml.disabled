---
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: myapp-monitoring-environments
  namespace: argocd
spec:
  goTemplate: true
  goTemplateOptions:
    - missingkey=error
  generators:
    - list:
        elements:
          - environment: dev
            namespace: monitoring
            autoSync: "true"
            targetRevision: main
          - environment: staging
            namespace: monitoring
            autoSync: "true"
            targetRevision: main
          - environment: prod
            namespace: monitoring
            autoSync: "false"
            targetRevision: main
  template:
    metadata:
      name: myapp-monitoring-{{.environment}}
      labels:
        app.kubernetes.io/part-of: myapp
        app.kubernetes.io/component: monitoring
        app.kubernetes.io/environment: "{{.environment}}"
    spec:
      project: default
      source:
        repoURL: https://github.com/gMpHSpLB/pythonworkspace.git
        targetRevision: "{{.targetRevision}}"
        path: infra/k8s/monitoring
      destination:
        server: https://kubernetes.default.svc
        namespace: "{{.namespace}}"
      syncPolicy:
        syncOptions:
          - CreateNamespace=true
  templatePatch: |
    {{- if eq .autoSync "true" }}
    spec:
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
    {{- end }}
