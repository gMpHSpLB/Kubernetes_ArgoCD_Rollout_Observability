{{- if eq .Values.global.environment "staging" }}
apiVersion: v1
kind: ConfigMap
metadata:
  name: cluster-monitoring-infra-s-grafana-datasource
  namespace: monitoring
  labels:
    app.kubernetes.io/name: grafana
    app.kubernetes.io/instance: cluster-monitoring-infra-staging
    app.kubernetes.io/component: datasource
data:
  datasource.yaml: |
    apiVersion: 1
    datasources:
      - name: Prometheus
        type: prometheus
        access: proxy
        url: http://cluster-monitoring-infra-s-prometheus.monitoring:9090
        isDefault: true
        jsonData:
          timeInterval: "30s"

      - name: Alertmanager
        type: alertmanager
        access: proxy
        url: http://cluster-monitoring-infra-s-alertmanager.monitoring:9093
        jsonData:
          implementation: "prometheus"

      - name: Loki
        type: loki
        access: proxy
        url: http://myapp-logging-staging-loki.logging:3100
        jsonData:
          maxLines: 1000
{{- end }}