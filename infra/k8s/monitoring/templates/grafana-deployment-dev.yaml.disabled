{{- if eq .Values.global.environment "dev" }}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: cluster-monitoring-infra-dev-grafana
  namespace: monitoring
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: grafana
      app.kubernetes.io/instance: cluster-monitoring-infra-dev
  template:
    metadata:
      labels:
        app.kubernetes.io/name: grafana
        app.kubernetes.io/instance: cluster-monitoring-infra-dev
    spec:
      serviceAccountName: cluster-monitoring-infra-grafana
      securityContext:
        runAsNonRoot: true
        runAsUser: 472
        runAsGroup: 472
        fsGroup: 472
      containers:
        - name: grafana
          image: {{ .Values.grafana.image | default "grafana/grafana:10.4.5" }}
          imagePullPolicy: IfNotPresent
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop: ["ALL"]
          env:
            - name: GF_SECURITY_ADMIN_USER
              valueFrom:
                secretKeyRef:
                  name: {{ .Values.grafana.security.adminUserSecret }}
                  key: {{ .Values.grafana.security.adminUserKey }}
            - name: GF_SECURITY_ADMIN_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ .Values.grafana.security.adminUserSecret }}
                  key: {{ .Values.grafana.security.adminPasswordKey }}
            - name: GF_PATHS_PROVISIONING
              value: /etc/grafana/provisioning
            - name: GF_PATHS_DATA
              value: /var/lib/grafana
            - name: GF_PATHS_LOGS
              value: /var/log/grafana
            - name: GF_PATHS_PLUGINS
              value: /var/lib/grafana/plugins
          volumeMounts:
            - name: grafana-storage
              mountPath: /var/lib/grafana
            - name: grafana-logs
              mountPath: /var/log/grafana
            - name: grafana-datasource
              mountPath: /etc/grafana/provisioning/datasources/datasource.yaml
              subPath: datasource.yaml
            - name: grafana-dashboards-provisioning
              mountPath: /etc/grafana/provisioning/dashboards/dashboards.yaml
              subPath: dashboards.yaml
            - name: grafana-dashboards-infra
              mountPath: /var/lib/grafana/dashboards/infra
            - name: grafana-dashboards-myapp
              mountPath: /var/lib/grafana/dashboards/myapp
            - name: grafana-ini
              mountPath: /etc/grafana/grafana.ini
              subPath: grafana.ini
          ports:
            - name: http
              containerPort: 3000
          readinessProbe:
            httpGet:
              path: /api/health
              port: http
          livenessProbe:
            httpGet:
              path: /api/health
              port: http
      volumes:
        - name: grafana-storage
          persistentVolumeClaim:
            claimName: grafana-storage-dev
        - name: grafana-logs
          emptyDir: {}
        - name: grafana-datasource
          configMap:
            name: cluster-monitoring-infra-d-grafana-datasource
        - name: grafana-dashboards-provisioning
          configMap:
            name: grafana-dashboards-provisioning-dev
        - name: grafana-dashboards-infra
          configMap:
            name: grafana-dashboards-infra-dev
        - name: grafana-dashboards-myapp
          configMap:
            name: grafana-dashboards-myapp-dev
        - name: grafana-ini
          configMap:
            name: cluster-monitoring-infra-dev-grafana-ini
{{- end }}
