name: Monorepo CI

on: # this is GitHub Actions trigger
  push: #CI . 'git push'
    branches: [ main ] # main is production branch


jobs:
  # ---------- CI - Need to run docker only ----------
  docker:
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v3

    - name: Build Docker images
      run: docker compose build

    - name: Run Docker tests
      run: make test-docker

    - name: Check API
      run: |
        make run
        make check-api
