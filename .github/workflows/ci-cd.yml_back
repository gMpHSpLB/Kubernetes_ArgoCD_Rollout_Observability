name: Monorepo CI-CD pipeline # For dev/staging/prod environment
#1. Build Promotion Flow: You don’t just run CI once — you run different stages for different environments
#     build once → promote many times
#     dev → staging → prod (same image is promoted to different environment)
#2. Each environment has:
#     - its own purpose
#     - its own trigger
#     - its own level of strictness
#3. DEV (Continuous Integration)
#     - Trigger: every push
#     - pytest -> lint -> docker build -> (optional) push :dev image
#4. STAGING (Pre-production validation)
#     - Trigger: manual / PR merge / promotion
#     - promote :dev -> :staging
#     - use built image -> integration tests -> API checks
#5. PROD (Release / CD)
#     - Trigger: git tag (v1.0.0)
#     - promote :staging -> vX.X.X
#     - tag image -> push to registry -> deploy (optional)
#6. As we are using Github, we will add environment protection (in GitHub, Settings → Environments)
#     - Create dev, staging, production
#Explaination for below jobs:
#ci runs on every relevant execution and computes shared image names once.
#deploy-dev pushes immutable dev images to GHCR.
#deploy-staging is manual through workflow_dispatch, so you can control promotion.
#deploy-prod runs only for version tags like v1.0.0. if: conditions for tag-based production deploys
#GitHub Environments can protect staging and production with approvals and secrets
#7. Also add 12-factors style config:
#     Follow the “config in environment variables” pattern (12‑factor style):
#     app reads everything from env vars, and each environment provides different
#     values
on: # this is GitHub Actions trigger
  push: #Both CI and CD happens. 'git tag v1.0.0' then 'git push origin v1.0.0'
    branches: [main]
    tags:
      - "v*" # trigger only on version tags

  #GitHub Actions. It uses workflow_dispatch for controlled staging promotion,
  #tag-based production deploys, environment protection, and shared values passed
  #with job outputs. GitHub Actions supports manual triggers, environment protection rules,
  #and passing outputs between jobs this way.
  workflow_dispatch: #for manual staging deploys
    inputs:
      promote_to_staging:
        description: "Promote current dev image to staging"
        required: false
        type: boolean
        default: false

permissions: #Add permissions in workflow. Make sure to Enable package permissions in Github : Enable package permissions
  contents: read
  packages: write

env:
  REGISTRY: ghcr.io

jobs:
  # You will split your pipeline into 3 logical stages(dev,staging/prod) but CI job will run always
  # CI job (always runs)
  #For our workflow, the cleanest approach is
  #    Set shared values in the ci job.
  #    Expose them as job outputs.
  #    Read them in deploy-dev and deploy-staging using needs.ci.outputs...
  ci:
    runs-on: ubuntu-latest
    outputs:
      repo_lower: ${{ steps.vars.outputs.repo_lower }}
      image_myapp_dev: ${{ steps.vars.outputs.image_myapp_dev }}
      image_mylearning_dev: ${{ steps.vars.outputs.image_mylearning_dev }}
      image_myapp_staging: ${{ steps.vars.outputs.image_myapp_staging }}
      image_mylearning_staging: ${{ steps.vars.outputs.image_mylearning_staging }}
      image_myapp_prod: ${{ steps.vars.outputs.image_myapp_prod }}
      image_mylearning_prod: ${{ steps.vars.outputs.image_mylearning_prod }}

    steps:
      #Below command tells GitHub Actions to run the official checkout action version 4, which downloads your repository code into the runner so later steps can use it. Without it, commands like docker build, ls, or cat usually won’t have your project files available
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install Poetry
        run: |
          pip install poetry
          poetry --version

      - name: Install dependencies (dev tools included)
        run: |
          cd myapp
          poetry install --with dev --no-root --no-interaction --no-ansi
          cd ../mylearning
          poetry install --with dev --no-root --no-interaction --no-ansi

      - name: Code quality checks (ruff + mypy + bandit+ format)
        run: make quality

      #It runs Safety CLI’s scan against your repo, detecting vulnerable Python packages from files such as pyproject.toml, poetry.lock, requirements.txt, and virtualenvs.
      #It does not inspect your Dockerfile, built images, OS packages, or other language ecosystems.
      - name: Run Safety CLI to check for vulnerabilities
        uses: pyupio/safety-action@v1
        with:
          api-key: ${{ secrets.SAFETY_API_KEY }}

      - name: Tests (local style)
        run: make test

      - id: vars
        name: Set shared variables
        run: |
          REPO_LOWER=$(echo '${{ github.repository }}' | tr '[:upper:]' '[:lower:]')
          echo "repo_lower=$REPO_LOWER" >> $GITHUB_OUTPUT
          echo "image_myapp_dev=${REGISTRY}/$REPO_LOWER/myapp:dev" >> $GITHUB_OUTPUT
          echo "image_mylearning_dev=${REGISTRY}/$REPO_LOWER/mylearning:dev" >> $GITHUB_OUTPUT
          echo "image_myapp_staging=${REGISTRY}/$REPO_LOWER/myapp:staging" >> $GITHUB_OUTPUT
          echo "image_mylearning_staging=${REGISTRY}/$REPO_LOWER/mylearning:staging" >> $GITHUB_OUTPUT
          if [[ "${GITHUB_REF}" == refs/tags/v* ]]; then
            VERSION="${GITHUB_REF_NAME}"
          else
            VERSION="latest"
          fi
          echo "image_myapp_prod=${REGISTRY}/$REPO_LOWER/myapp:$VERSION" >> $GITHUB_OUTPUT
          echo "image_mylearning_prod=${REGISTRY}/$REPO_LOWER/mylearning:$VERSION" >> $GITHUB_OUTPUT

      - name: Build Docker images
        run: docker compose build

      - name: Run Docker tests
        run: make test-docker

      - name: Check API
        run: |
          make run
          make check-api

      - name: Validate Docker credentials
        env:
          DOCKER_USERNAME: ${{ secrets.DOCKER_USERNAME }}
          DOCKER_PASSWORD: ${{ secrets.DOCKER_PASSWORD }}
        run: |
          : "${DOCKER_USERNAME:?DOCKER_USERNAME is required}"
          : "${DOCKER_PASSWORD:?DOCKER_PASSWORD is required}"
          echo "CI Docker credentials Environments are OK."

      # ---- DockerHub Login ----
      - name: Docker login
        env:
          DOCKER_USERNAME: ${{ secrets.DOCKER_USERNAME }}
          DOCKER_PASSWORD: ${{ secrets.DOCKER_PASSWORD }}
        run: echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin


      # ---- Docker image CVE scan (Docker Scout) ----
      - name: Docker image security scan (Docker Scout)
        run: make docker-scan

    ## Code Coverage.
      - name: Upload myapp coverage
        uses: actions/upload-artifact@v4
        with:
          name: coverage-myapp
          path: myapp/coverage-myapp.xml

      - name: Upload mylearning coverage
        uses: actions/upload-artifact@v4
        with:
          name: coverage-mylearning
          path: mylearning/coverage-mylearning.xml

      #Code covrage using Codecov - In future we can use it but right now we have disbaled it.
      # codecov/codecov-action@v5 is the current action that wraps the CLI;
      # tokenless upload is no longer supported,
      # so you must set CODECOV_TOKEN in GitHub secrets (get it from Codecov’s repo settings).
      # flags give you separate views for myapp and mylearning inside one monorepo.
      #- name: Upload myapp coverage to Codecov
      # uses: codecov/codecov-action@v5
      #  with:
      #    files: myapp/coverage-myapp.xml
      #    flags: myapp
      #    name: myapp
      #    fail_ci_if_error: true
      #    token: ${{ secrets.CODECOV_TOKEN }}

      #- name: Upload mylearning coverage to Codecov
      #  uses: codecov/codecov-action@v5
      #  with:
      #    files: mylearning/coverage-mylearning.xml
      #    flags: mylearning
      #    name: mylearning
      #    fail_ci_if_error: true
      #    token: ${{ secrets.CODECOV_TOKEN }}

      - name: List coverage files
        run: |
          ls -R
          ls -l myapp/coverage-myapp.xml
          ls -l mylearning/coverage-mylearning.xml

      # Add a coverage summary to the GitHub Actions job
      # Use the Code Coverage Summary action to read your two XML files and produce a Markdown summary in the job log and summary.
      - name: Coverage Summary
        uses: irongut/CodeCoverageSummary@v1.3.0
        with:
          filename: '**/coverage-*.xml'
          format: 'markdown'
          output: 'both'        # console + file
          badge: 'false'        # You can set it true to get screenshot like file.
          fail_below_min: 'false'
          hide_branch_rate: 'false'
          hide_complexity: 'false'
          indicators: 'true'
          thresholds: '50 75'

      - name: Append coverage to job summary
        if: always()
        run: |
          if [ -f code-coverage-results.md ]; then
            echo "" >> "$GITHUB_STEP_SUMMARY"
            cat code-coverage-results.md >> "$GITHUB_STEP_SUMMARY"
          fi

      - name: Clean all
        run: |
          make clean

  # CD - Dev (auto deploy)
  # It triggered/runs when
  #    push code to the repository (like: git push origin main), or.
  #    manually run the workflow from the GitHub Actions UI
  deploy-dev:
    needs: ci
    runs-on: ubuntu-latest
    environment: dev
    #run the job or step only when the workflow was triggered either by a push event or by a manual run from the GitHub Actions UI. GitHub Actions commonly uses github.event_name to distinguish which event started the workflow.
    #github.event_name == 'push' means the workflow was started by a code push.
    #github.event_name == 'workflow_dispatch' means the workflow was started manually.
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'

    steps:
      - uses: actions/checkout@v4

      #config validation step at the start of each deploy job. Using defaults if no env overrides
      - name: Validate dev config
        run: |
          : "${DB_HOST:=db}"
          : "${DB_PORT:=5432}"
          : "${DB_NAME:=mydb}"
          : "${DB_USER:=myuser}"
          : "${DB_PASSWORD:=mypassword}"
          echo "Dev DB config looks reasonable."

      - name: Login to GitHub_Container_Registry # Use GITHUB_TOKEN (not using PAT )
        # Below line:
        # It logs your CI pipeline into GitHub Container Registry so Docker can push images securely
        # secrets.GITHUB_TOKEN - This is an auto-generated secure token from GitHub.
        #       No need to create manually
        #       Valid only during workflow run
        #       Has permission to push images to your repo
        # docker login ghcr.io
        #      This tells Docker: “I want to authenticate with GitHub Container Registry”
        # -u ${{ github.actor }} : Username = GitHub user who triggered the workflow
        # --password-stdin : Tells Docker: “Read password from input (stdin), not from command line”
        run: echo "${{ secrets.GITHUB_TOKEN }}" | docker login ghcr.io -u ${{ github.actor }} --password-stdin

      - name: Build and Push dev images #Push images to registry
        #builds a Docker image from the Dockerfile inside the ./myapp directory,
        #   and tags the resulting image with the name stored in IMAGE_MYAPP.
        #   The build context is ./myapp, so Docker sends that folder’s contents to the build process.
        #   It does not read docker-compose.yml file.
        #Reused those outputs in later jobs with needs.ci.outputs...
        run: |
          docker build -t ${{ needs.ci.outputs.image_myapp_dev }} ./myapp
          docker build -t ${{ needs.ci.outputs.image_mylearning_dev }} ./mylearning
          docker push ${{ needs.ci.outputs.image_myapp_dev }}
          docker push ${{ needs.ci.outputs.image_mylearning_dev }}

      # ---- DockerHub Login ----
      - name: Docker login
        env:
          DOCKER_USERNAME: ${{ secrets.DOCKER_USERNAME }}
          DOCKER_PASSWORD: ${{ secrets.DOCKER_PASSWORD }}
        run: echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin

      - name: Docker image security scan (Docker Scout) - dev images
        run: |
          make docker-scan-dev-image IMAGE=${{ needs.ci.outputs.image_myapp_dev }}
          make docker-scan-dev-image IMAGE=${{ needs.ci.outputs.image_mylearning_dev }}

      - name: Run dev stack from registry images
        #docker compose is better when you want the configuration saved in
        #a file (YAML), especially if your app uses multiple services that need to
        #start together.
        #docker compose -f docker-compose.dev.yml up -d
        #     Creates and starts the containers for all services defined in
        #     that file (or only the services you name after up).If images do not exist yet for services with build:, Compose
        #     will build them first, then start the containers. -d (detached mode) Runs the containers in the background, returning control to your terminal immediately.
        #     -f tells docker compose which compose file to use, instead of the default one.
        env:
          IMAGE_MYAPP_DEV: ${{ needs.ci.outputs.image_myapp_dev }}
          IMAGE_MYLEARNING_DEV: ${{ needs.ci.outputs.image_mylearning_dev }}
          APP_ENV: dev
          DB_HOST: db
          DB_PORT: 5432
          DB_NAME: mydb
          DB_USER: myuser
          DB_PASSWORD: mypassword
        run: |
          docker compose -f docker-compose.dev.yml down -v --remove-orphans
          docker compose -f docker-compose.dev.yml up -d
          sleep 15
          #Can Run pytest explicilty for boths if dev dependecies are installed in images. Please check the Dockerfile to confirm devdependecies are install or not.
          #Note: Rightnow, We are not installing devlopment dependencies in dev/staging/prod images as we want to acchiev build once promote many approach.
          #docker compose -f docker-compose.dev.yml run --rm myapp poetry run pytest
          #docker compose -f docker-compose.dev.yml run --rm mylearning poetry run pytest

      - name: Run dev API checks
        run: |
          sleep 10
          curl -f http://localhost:8000/docs || exit 1

      - name: Tear down dev stack
        env:
          IMAGE_MYAPP_DEV: ${{ needs.ci.outputs.image_myapp_dev }}
          IMAGE_MYLEARNING_DEV: ${{ needs.ci.outputs.image_mylearning_dev }}
        if: always()
        run: docker compose -f docker-compose.dev.yml down -v

  # CD - Staging (controlled)
  # This runs when you manually trigger the workflow in GitHub Actions and choose promote_to_staging = true.
  deploy-staging:
    needs: [ci, deploy-dev] #needs: deploy-dev, which would not let it access outputs from ci unless it also depended on ci
    runs-on: ubuntu-latest
    environment: staging
    # manual through workflow_dispatch, so you can control promotion.
    # GitHub Actions supports boolean workflow_dispatch inputs, so this condition becomes true only when you manually trigger the workflow and check that input.
    # If you want it to be true
    #    When you click Run workflow in GitHub Actions, set Promote dev image to staging to true. If it is left unchecked, it will be false.
    if: github.event_name == 'workflow_dispatch' && inputs.promote_to_staging == true

    steps:
      - uses: actions/checkout@v4

      #Validation for deploy-staging:
      #Staging should fail fast if any required env var or secret is missing.
      #Use GitHub Environment secrets for staging (e.g. STAGING_DB_HOST, STAGING_DB_USER, etc.)
      - name: Validate staging config
        env:
          STAGING_DB_HOST: ${{ secrets.STAGING_DB_HOST }}
          STAGING_DB_PORT: ${{ secrets.STAGING_DB_PORT }}
          STAGING_DB_NAME: ${{ secrets.STAGING_DB_NAME }}
          STAGING_DB_USER: ${{ secrets.STAGING_DB_USER }}
          STAGING_DB_PASSWORD: ${{ secrets.STAGING_DB_PASSWORD }}
        run: |
          : "${STAGING_DB_HOST:?STAGING_DB_HOST is required}"
          : "${STAGING_DB_PORT:?STAGING_DB_PORT is required}"
          : "${STAGING_DB_NAME:?STAGING_DB_NAME is required}"
          : "${STAGING_DB_USER:?STAGING_DB_USER is required}"
          : "${STAGING_DB_PASSWORD:?STAGING_DB_PASSWORD is required}"
          echo "Staging DB config OK."

      - name: Login to GitHub Container Registry
        run: echo "${{ secrets.GITHUB_TOKEN }}" | docker login ${{ env.REGISTRY }} -u ${{ github.actor }} --password-stdin

      - name: Promote dev images to staging
        run: |
          docker pull ${{ needs.ci.outputs.image_myapp_dev }}
          docker tag ${{ needs.ci.outputs.image_myapp_dev }} ${{ needs.ci.outputs.image_myapp_staging }}
          docker push ${{ needs.ci.outputs.image_myapp_staging }}

          docker pull ${{ needs.ci.outputs.image_mylearning_dev }}
          docker tag ${{ needs.ci.outputs.image_mylearning_dev }} ${{ needs.ci.outputs.image_mylearning_staging }}
          docker push ${{ needs.ci.outputs.image_mylearning_staging }}

      #map to generic DB_* inside the job.
      #The compose file receives generic DB_* vars that your Python code reads
      - name: Run staging stack
        env:
          IMAGE_MYAPP_STAGING: ${{ needs.ci.outputs.image_myapp_staging }}
          IMAGE_MYLEARNING_STAGING: ${{ needs.ci.outputs.image_mylearning_staging }}
          DB_HOST: ${{ secrets.STAGING_DB_HOST }}
          DB_PORT: ${{ secrets.STAGING_DB_PORT }}
          DB_NAME: ${{ secrets.STAGING_DB_NAME }}
          DB_USER: ${{ secrets.STAGING_DB_USER }}
          DB_PASSWORD: ${{ secrets.STAGING_DB_PASSWORD }}
        run: |
          docker compose -f docker-compose.staging.yml down -v --remove-orphans
          docker compose -f docker-compose.staging.yml up -d
          sleep 15

      - name: Run staging API checks
        run: |
          sleep 10
          curl -f http://localhost:8000/docs || exit 1

      - name: Tear down staging stack
        env:
          IMAGE_MYAPP_STAGING: ${{ needs.ci.outputs.image_myapp_staging }}
          IMAGE_MYLEARNING_STAGING: ${{ needs.ci.outputs.image_mylearning_staging }}
        if: always()
        run: docker compose -f docker-compose.staging.yml down -v

  #This runs when you create and push a version tag like
  #    git tag v1.0.0
  #    git push origin v1.0.0
  deploy-prod:
    needs: [ci, deploy-staging]
    runs-on: ubuntu-latest
    environment: production
    #run this job or step only when the Git ref that triggered the workflow is a tag whose name starts with v. For example, it matches refs/tags/v1.0.0 but not refs/heads/main
    if: startsWith(github.ref, 'refs/tags/v')

    steps:
      - uses: actions/checkout@v4

        #Validation for deploy-prod: uses production environment secrets
        #prod should fail fast if any required env var or secret is missing.
        #Use GitHub Environment secrets for prod (e.g. PROD_DB_HOST, PROD_DB_USER, etc.)
      - name: Validate production config
        env:
          PROD_DB_HOST: ${{ secrets.PROD_DB_HOST }}
          PROD_DB_PORT: ${{ secrets.PROD_DB_PORT }}
          PROD_DB_NAME: ${{ secrets.PROD_DB_NAME }}
          PROD_DB_USER: ${{ secrets.PROD_DB_USER }}
          PROD_DB_PASSWORD: ${{ secrets.PROD_DB_PASSWORD }}
        run: |
          : "${PROD_DB_HOST:?PROD_DB_HOST is required}"
          : "${PROD_DB_PORT:?PROD_DB_PORT is required}"
          : "${PROD_DB_NAME:?PROD_DB_NAME is required}"
          : "${PROD_DB_USER:?PROD_DB_USER is required}"
          : "${PROD_DB_PASSWORD:?PROD_DB_PASSWORD is required}"
          echo "Produdtion DB config OK."

      - name: Login to GitHub Container Registry
        run: echo "${{ secrets.GITHUB_TOKEN }}" | docker login ${{ env.REGISTRY }} -u ${{ github.actor }} --password-stdin

      - name: Promote staging images to production #promotion staging → prod, with production secrets validated first.
        env:
          DB_HOST: ${{ secrets.PROD_DB_HOST }}
          DB_PORT: ${{ secrets.PROD_DB_PORT }}
          DB_NAME: ${{ secrets.PROD_DB_NAME }}
          DB_USER: ${{ secrets.PROD_DB_USER }}
          DB_PASSWORD: ${{ secrets.PROD_DB_PASSWORD }}
        run: |
          docker pull ${{ needs.ci.outputs.image_myapp_staging }}
          docker tag ${{ needs.ci.outputs.image_myapp_staging }} ${{ needs.ci.outputs.image_myapp_prod }}
          docker push ${{ needs.ci.outputs.image_myapp_prod }}

          docker pull ${{ needs.ci.outputs.image_mylearning_staging }}
          docker tag ${{ needs.ci.outputs.image_mylearning_staging }} ${{ needs.ci.outputs.image_mylearning_prod }}
          docker push ${{ needs.ci.outputs.image_mylearning_prod }}
